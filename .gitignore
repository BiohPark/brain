# ==========================================
# 1. 기본 규칙: 전체 무시 및 폴더 구조 탐색 허용
# ==========================================
*
!.gitignore
!*/
!**/

# ==========================================
# 2. [강제 제외] 절대 올라가면 안 되는 항목들 (맨 위에 선언)
# ==========================================
.mcp.json
.obsidian/plugins/
.obsidian/plugins/**

# ==========================================
# 3. [허용] 특정 루트 파일 및 폴더들
# ==========================================
!/CLAUDE.md
!/.mcp.json
!/🏛 Home.md
!/🏛 Tasks.md
!/🏛 Categories Tree.md
!/🏛 Categories.md

# ==========================================
# 4. [허용] .obsidian 하위 (plugins 제외한 나머지 전체)
# ==========================================
!/.obsidian/
!/.obsidian/*.json
!/.obsidian/snippets/
!/.obsidian/snippets/**
!/.obsidian/themes/
!/.obsidian/themes/**

# ==========================================
# 5. [허용] private 및 public 폴더 전체
# ==========================================
!/private/
!/private/90. Settings/
!/private/90. Settings/**

!/public/
!/public/**

# [반드시 제외] public 안으로 격리시킨 블로그 Git 폴더는 부모가 추적하지 않음
/public/BiohPark-github-blog/